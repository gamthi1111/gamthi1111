<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>function-pactory | 협업 프로그래밍 동아리</title>
  <meta name="description" content="2026년 시작된 협업 프로그래밍 동아리 function-pactory.">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700;900&family=Noto+Sans+KR:wght@300;400;500;700;900&family=Outfit:wght@300;400;600;800;900&display=swap');

    :root {
      --color-bg: #060608;
      --color-bg-card: rgba(13, 13, 17, 0.7);
      --color-mint: #00F5D4;
      --color-pink: #FF007F;
      --color-yellow: #FFE600;
      --color-text: #f8fafc;
      --color-text-muted: #94a3b8;
      --font-title: 'Outfit', 'Montserrat', sans-serif;
      --font-body: 'Noto Sans KR', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* 배경 그리드 */
    .bg-canvas {
      position: fixed; top: 0; left: 0;
      width: 100%; height: 100vh;
      z-index: 1; pointer-events: none;
      background:
        radial-gradient(circle at 50% 50%, rgba(20,20,30,0.5) 0%, var(--color-bg) 100%),
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 100% 100%, 40px 40px, 40px 40px;
      transition: transform 0.1s ease-out;
    }

    /* 배경 글로우 */
    .bg-glow { position: fixed; z-index: 1; pointer-events: none; border-radius: 50%; }
    .bg-glow-mint {
      top: 20%; left: 15%; width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(0,245,212,0.15) 0%, transparent 70%);
      filter: blur(40px);
    }
    .bg-glow-pink {
      bottom: 10%; right: 10%; width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(255,0,127,0.12) 0%, transparent 70%);
      filter: blur(50px);
    }
    .bg-glow-yellow {
      top: 50%; left: 60%; width: 350px; height: 350px;
      background: radial-gradient(circle, rgba(255,230,0,0.1) 0%, transparent 70%);
      filter: blur(30px);
    }

    /* 헤더 */
    header {
      position: fixed; top: 0; left: 0; width: 100%;
      padding: 1.5rem 5%;
      display: flex; justify-content: space-between; align-items: center;
      z-index: 100;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .logo {
      font-family: var(--font-title); font-weight: 900; font-size: 1.8rem;
      color: var(--color-text); text-decoration: none;
      display: flex; align-items: center; gap: 0.3rem;
    }

    .logo .factory {
      background: linear-gradient(135deg, var(--color-mint) 0%, var(--color-pink) 50%, var(--color-yellow) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; position: relative;
    }

    .logo .factory::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      width: 100%; height: 2px;
      background: linear-gradient(90deg, var(--color-mint), var(--color-pink), var(--color-yellow));
      box-shadow: 0 0 8px rgba(0,245,212,0.5);
    }

    nav ul { display: flex; list-style: none; gap: 2.5rem; }

    nav ul li a {
      text-decoration: none; color: var(--color-text-muted);
      font-family: var(--font-title); font-weight: 600; font-size: 1rem;
      transition: all 0.3s ease; position: relative;
    }

    nav ul li a:hover { color: var(--color-text); }

    nav ul li a::after {
      content: ''; position: absolute; width: 0; height: 2px;
      bottom: -4px; left: 0;
      background-color: var(--color-pink);
      transition: width 0.3s ease;
    }

    nav ul li a:hover::after { width: 100%; }
    nav ul li a.active-link { color: var(--color-mint); }
    nav ul li a.active-link::after { background-color: var(--color-mint); width: 100%; }

    /* 3D 뷰포트 */
    .view-viewport {
      position: relative; width: 100%; min-height: 100vh;
      perspective: 1200px;
      display: flex; justify-content: center; align-items: center;
      padding: 8rem 2rem 4rem 2rem;
      z-index: 10;
    }

    .scene-container {
      width: 100%; max-width: 1200px;
      transform-style: preserve-3d;
      transition: transform 0.12s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    /* 히어로 그리드 */
    .hero-content {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem; align-items: center;
      transform-style: preserve-3d;
    }

    @media (max-width: 968px) {
      .hero-content { grid-template-columns: 1fr; gap: 3rem; }
    }

    /* 소개 패널 */
    .intro-panel {
      background: var(--color-bg-card);
      backdrop-filter: blur(15px);
      border-radius: 24px; padding: 3.5rem;
      border: 1px solid rgba(255,255,255,0.05);
      box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
      transform: translateZ(50px);
      transform-style: preserve-3d;
      position: relative; overflow: hidden;
    }

    .intro-panel::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 4px; height: 100%;
      background: linear-gradient(to bottom, var(--color-mint), var(--color-pink), var(--color-yellow));
    }

    .start-year-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(255,230,0,0.1);
      border: 1px solid rgba(255,230,0,0.3);
      color: var(--color-yellow);
      padding: 0.5rem 1.2rem; border-radius: 30px;
      font-family: var(--font-title); font-weight: 800; font-size: 0.9rem;
      text-transform: uppercase; margin-bottom: 1.5rem;
    }

    .badge-dot {
      display: inline-block; width: 6px; height: 6px;
      background-color: var(--color-yellow);
      border-radius: 50%; box-shadow: 0 0 8px var(--color-yellow);
      animation: pulse 1.5s infinite;
    }

    h1.hero-title {
      font-family: var(--font-title); font-weight: 900;
      font-size: 3.8rem; line-height: 1.1;
      margin-bottom: 2rem; letter-spacing: -2px;
    }

    @media (max-width: 480px) { h1.hero-title { font-size: 2.5rem; } }

    h1.hero-title .color-part {
      background: linear-gradient(90deg, var(--color-mint) 0%, var(--color-pink) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .main-desc {
      font-size: 1.15rem; line-height: 1.9;
      color: var(--color-text); font-weight: 400; word-break: keep-all;
    }

    .kw-mint { color: var(--color-mint); font-weight: 700; text-shadow: 0 0 10px rgba(0,245,212,0.3); }
    .kw-pink { color: var(--color-pink); font-weight: 700; text-shadow: 0 0 10px rgba(255,0,127,0.3); }
    .kw-yellow { color: var(--color-yellow); font-weight: 700; text-shadow: 0 0 10px rgba(255,230,0,0.3); }

    .meta-stats {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem; margin-top: 3rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding-top: 2rem;
    }

    .stat-item { text-align: center; }

    .stat-val {
      font-family: var(--font-title); font-size: 2rem;
      font-weight: 800; line-height: 1; margin-bottom: 0.5rem;
    }

    .stat-val.mint { color: var(--color-mint); }
    .stat-val.pink { color: var(--color-pink); }
    .stat-val.yellow { color: var(--color-yellow); }
    .stat-label { font-size: 0.8rem; color: var(--color-text-muted); font-weight: 500; }

    /* 3D 큐브 */
    .visual-panel {
      display: flex; justify-content: center; align-items: center;
      height: 400px; position: relative;
      transform-style: preserve-3d; transform: translateZ(80px);
    }

    .glow-cube {
      position: relative; width: 200px; height: 200px;
      transform-style: preserve-3d;
      animation: spin 18s linear infinite;
    }

    .cube-face {
      position: absolute; width: 200px; height: 200px;
      background: rgba(10,10,14,0.85);
      border: 2px solid; border-radius: 12px;
      display: flex; justify-content: center; align-items: center;
      font-family: var(--font-title); font-weight: 900; font-size: 1.3rem;
    }

    .cube-face.front  { transform: rotateY(0deg) translateZ(100px);    border-color: var(--color-mint);   color: var(--color-mint);   box-shadow: 0 0 25px rgba(0,245,212,0.3); }
    .cube-face.back   { transform: rotateY(180deg) translateZ(100px);  border-color: var(--color-pink);   color: var(--color-pink);   box-shadow: 0 0 25px rgba(255,0,127,0.3); }
    .cube-face.right  { transform: rotateY(90deg) translateZ(100px);   border-color: var(--color-yellow); color: var(--color-yellow); box-shadow: 0 0 25px rgba(255,230,0,0.3); }
    .cube-face.left   { transform: rotateY(-90deg) translateZ(100px);  border-color: var(--color-mint);   color: var(--color-mint);   box-shadow: 0 0 25px rgba(0,245,212,0.3); }
    .cube-face.top    { transform: rotateX(90deg) translateZ(100px);   border-color: var(--color-pink);   color: var(--color-pink);   box-shadow: 0 0 25px rgba(255,0,127,0.3); }
    .cube-face.bottom { transform: rotateX(-90deg) translateZ(100px);  border-color: var(--color-yellow); color: var(--color-yellow); box-shadow: 0 0 25px rgba(255,230,0,0.3); }

    /* 떠다니는 요소들 */
    .floating-el {
      position: absolute; font-family: var(--font-title); font-weight: 800;
      pointer-events: none; user-select: none;
      animation: float 6s ease-in-out infinite alternate;
    }
    .fe1 { top: 8%;  left: -8%;  font-size: 2.8rem; color: var(--color-mint);   opacity: 0.13; animation-delay: 0s; }
    .fe2 { bottom: 8%; left: 18%; font-size: 1.8rem; color: var(--color-pink);   opacity: 0.18; animation-delay: 1.2s; }
    .fe3 { top: 22%; right: -4%; font-size: 2.2rem; color: var(--color-yellow); opacity: 0.22; animation-delay: 2.4s; }
    .fe4 { bottom: 20%; right: 35%; font-size: 1.4rem; color: var(--color-mint); opacity: 0.16; animation-delay: 3.6s; }

    /* 가치 섹션 */
    .values-section {
      max-width: 1200px; width: 100%;
      margin: 6rem auto 0 auto;
      z-index: 10; position: relative; padding: 0 2rem;
    }

    .values-title {
      text-align: center; font-family: var(--font-title);
      font-size: 2.5rem; font-weight: 800;
      margin-bottom: 3rem; letter-spacing: -1px;
    }

    .values-title span { color: var(--color-mint); }

    .values-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .value-card {
      background: var(--color-bg-card); backdrop-filter: blur(10px);
      border-radius: 20px; padding: 2.5rem;
      border: 1px solid rgba(255,255,255,0.04);
      transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
      cursor: pointer; position: relative; overflow: hidden;
    }

    .value-card:hover { transform: translateY(-10px); }

    .value-card.mint-card:hover  { box-shadow: 0 15px 40px rgba(0,245,212,0.12);  border-color: rgba(0,245,212,0.3); }
    .value-card.pink-card:hover  { box-shadow: 0 15px 40px rgba(255,0,127,0.12);  border-color: rgba(255,0,127,0.3); }
    .value-card.yellow-card:hover { box-shadow: 0 15px 40px rgba(255,230,0,0.12); border-color: rgba(255,230,0,0.3); }

    .card-num {
      font-family: var(--font-title); font-size: 3rem; font-weight: 900;
      line-height: 1; margin-bottom: 1rem; opacity: 0.12;
      transition: opacity 0.3s ease;
    }
    .value-card:hover .card-num { opacity: 0.8; }

    .mint-card .card-num   { color: var(--color-mint); }
    .pink-card .card-num   { color: var(--color-pink); }
    .yellow-card .card-num { color: var(--color-yellow); }

    .card-title {
      font-family: var(--font-title); font-size: 1.4rem;
      font-weight: 700; margin-bottom: 1rem;
    }
    .mint-card .card-title   { color: var(--color-mint); }
    .pink-card .card-title   { color: var(--color-pink); }
    .yellow-card .card-title { color: var(--color-yellow); }

    .card-desc { font-size: 0.95rem; line-height: 1.6; color: var(--color-text-muted); }

    /* 푸터 */
    footer {
      text-align: center; padding: 4rem 2rem; margin-top: 6rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      z-index: 10; position: relative;
      font-family: var(--font-title); font-size: 0.9rem;
      color: var(--color-text-muted);
    }
    footer span { color: var(--color-mint); font-weight: 600; }

    /* 커서 글로우 */
    .cursor-glow {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(0,245,212,0.06) 0%, rgba(255,0,127,0.03) 50%, transparent 70%);
      border-radius: 50%; position: fixed; pointer-events: none;
      z-index: 2; transform: translate(-50%, -50%);
      transition: left 0.05s, top 0.05s;
    }

    /* 애니메이션 */
    @keyframes pulse {
      0%   { transform: scale(1); opacity: 0.6; }
      50%  { transform: scale(1.4); opacity: 1; box-shadow: 0 0 12px var(--color-yellow); }
      100% { transform: scale(1); opacity: 0.6; }
    }

    @keyframes spin {
      0%   { transform: rotateX(0deg) rotateY(0deg); }
      100% { transform: rotateX(360deg) rotateY(360deg); }
    }

    @keyframes float {
      0%   { transform: translateY(0px) rotate(-3deg); }
      100% { transform: translateY(-22px) rotate(8deg); }
    }
  </style>
</head>
<body>

