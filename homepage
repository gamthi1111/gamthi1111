  <script>
    const scene = document.getElementById('sceneContainer');
    const bg = document.getElementById('bgCanvas');
    const glow = document.getElementById('cursorGlow');

    let mouseX = 0, mouseY = 0;
    let curX = 0, curY = 0, curTX = 0, curTY = 0;

    const TILT = 22;    // 최대 기울기 (도)
    const MOVE = 55;    // 최대 이동 (px)
    const LERP = 0.08;  // 부드러움 (작을수록 부드러움)

    window.addEventListener('mousemove', (e) => {
      glow.style.left = e.clientX + 'px';
      glow.style.top  = e.clientY + 'px';
      mouseX = (e.clientX / window.innerWidth)  - 0.5;  // -0.5 ~ 0.5
      mouseY = (e.clientY / window.innerHeight) - 0.5;
    });

    function tick() {
      const tRY =  mouseX * TILT;
      const tRX = -mouseY * TILT;
      const tTX =  mouseX * MOVE;
      const tTY =  mouseY * MOVE * 0.6;

      curX  += (tRX - curX)  * LERP;
      curY  += (tRY - curY)  * LERP;
      curTX += (tTX - curTX) * LERP;
      curTY += (tTY - curTY) * LERP;

      scene.style.transform =
        `rotateX(${curX.toFixed(2)}deg) rotateY(${curY.toFixed(2)}deg) translateX(${curTX.toFixed(2)}px) translateY(${curTY.toFixed(2)}px)`;

      bg.style.transform =
        `scale(1.08) translate(${(-curTX * 0.3).toFixed(2)}px, ${(-curTY * 0.3).toFixed(2)}px)`;

      requestAnimationFrame(tick);
    }

    tick();
  </script>
